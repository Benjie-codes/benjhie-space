---
import { Image } from "astro:assets";
import { cn } from "src/utils";

// Importing the new project images
import grydImg from "$assets/projects/projects/gryd-img.png";
import kobooImg from "$assets/projects/projects/koboo-img.png";
import chatifyImg from "$assets/projects/projects/chatify-img.png";
import sumlyImg from "$assets/projects/projects/sumly-img.png";
import habitImg from "$assets/projects/projects/habit-img.png";
import invoiceImg from "$assets/projects/projects/invoice-img.png";

const projects = [
  {
    name: "Gryd",
    thumbnail: grydImg,
    projectUrl: "https://gryd-seven.vercel.app/",
    shortDescription: "A web-based stylized gradient generator and editor.",
    aspect: "aspect-[16/10]"
  },
  {
    name: "Koboo",
    thumbnail: kobooImg,
    projectUrl: "https://koboo-ten.vercel.app/",
    shortDescription: "Nigerian based tax calculator based off the 2026 tax ammendment.",
    aspect: "aspect-[16/10]"
  },
  {
    name: "Chatify",
    thumbnail: chatifyImg,
    projectUrl: "https://chatify-topaz-delta.vercel.app/",
    shortDescription: "A E2EE encrypted chat application using WhisperBox api.",
    aspect: "aspect-[16/10]"
  },
  {
    name: "Sumly",
    thumbnail: sumlyImg,
    projectUrl: "https://github.com/Benjie-codes/sumly",
    shortDescription: "A chrome extension that use AI to summarize web pages.",
    aspect: "aspect-[16/10]"
  },
  {
    name: "Habit Tracker",
    thumbnail: habitImg,
    projectUrl: "https://habiti-five.vercel.app/",
    shortDescription: "A simple PWA for tracking your habits.",
    aspect: "aspect-[16/10]"
  },
  {
    name: "Invoice Generator",
    thumbnail: invoiceImg,
    projectUrl: "https://invoice-app-liart-five.vercel.app/",
    shortDescription: "A web-based application for generating and managing invoices.",
    aspect: "aspect-[16/10]"
  }
];
---

<div
  id="projects"
  class="z-20 py-16 md:py-32 section bg-background relative isolate overflow-hidden"
>
  <div class="mx-auto max-w-5xl px-6 lg:px-8">
    <div class="max-w-2xl mb-12">
      <h1
        class="text-4xl font-bold tracking-tight text-base-800 dark:text-base-100 sm:text-5xl"
      >
        Projects
      </h1>
      <div class="mt-6 text-base text-base-600 dark:text-base-400">
        i've worked on a lot of projects, here are a few of them, some of them are open-source, so if you see something that piques your interest, you can check them out.
      </div>
    </div>

    <div
      class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8 group/projects"
    >
      {
        projects.map((project) => (
          <div class="w-full">
            <a 
              href={project.projectUrl} 
              target="_blank"
              rel="noopener noreferrer"
              class="group relative block overflow-hidden rounded-3xl border border-white/10 transition-all duration-300 hover:border-accent-500/50 hover:shadow-2xl hover:shadow-accent-500/10"
            >
              <div class={cn("relative w-full", project.aspect)}>
                <Image
                  src={project.thumbnail}
                  alt={project.name}
                  class="absolute inset-0 h-full w-full object-cover transition-transform duration-500 group-hover:scale-110"
                  loading="lazy"
                />
                <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-transparent to-transparent opacity-60 group-hover:opacity-40 transition-opacity duration-300" />
              </div>
              
              <div class="p-6 bg-base-900/50 backdrop-blur-sm border-t border-white/5">
                <h3 class="text-xl font-bold text-white group-hover:text-accent-400 transition-colors">
                  {project.name}
                </h3>
                <p class="mt-2 text-sm text-base-400 line-clamp-2">
                  {project.shortDescription}
                </p>
                <div class="mt-4 flex items-center text-xs font-semibold text-accent-500">
                  Visit Site <span class="ml-1 transition-transform group-hover:translate-x-1">→</span>
                </div>
              </div>
            </a>
          </div>
        ))
      }
    </div>
  </div>
</div>
