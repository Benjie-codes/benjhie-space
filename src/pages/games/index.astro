---
import BaseLayout from "$layouts/BaseLayout.astro";
import Navbar from "$components/Navigation/Navbar.svelte";
import Footer from "$components/Footer.astro";
---

<BaseLayout title="Games">
  <Navbar client:load />
  
  <main class="mx-auto max-w-5xl px-6 lg:px-8 py-32">
    <div class="max-w-2xl">
      <h1 class="text-4xl font-bold tracking-tight text-base-800 dark:text-base-100 sm:text-5xl">
        Games
      </h1>
      <p class="mt-6 text-base text-base-600 dark:text-base-400">
        Welcome to the games section! I'll be implementing a simple snake game here soon. Stay tuned!
      </p>
      
      <div class="mt-12 p-12 border-2 border-dashed border-base-300 dark:border-base-800 rounded-3xl flex items-center justify-center text-base-400 italic">
        Snake game coming soon...
      </div>
      
      <div class="mt-8">
        <a href="/" class="text-accent-500 font-semibold hover:text-accent-400 transition-colors">
          &larr; Back to Home
        </a>
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>
