---
import BaseLayout from "$layouts/BaseLayout.astro";
import Navbar from "$components/Navigation/Navbar.svelte";
import SnakeGame from "$components/Games/SnakeGame.svelte";
---

<BaseLayout title="Games">
  <Navbar client:load />
  
  <main class="mx-auto max-w-5xl px-6 lg:px-8 py-32">
    <div class="flex flex-col lg:flex-row gap-16 items-start">
      <div class="max-w-xl">
        <h1 class="text-4xl font-bold tracking-tight text-base-800 dark:text-base-100 sm:text-5xl">
          Snake Game
        </h1>
        <p class="mt-6 text-base text-base-600 dark:text-base-400">
          A simple, nostalgic snake game built with Svelte. Use your arrow keys or WASD to navigate and collect the red orbs. Each orb increases your score and speed!
        </p>
        
        <div class="mt-8">
          <a href="/" class="text-accent-500 font-semibold hover:text-accent-400 transition-colors flex items-center gap-2">
            <span>&larr;</span> Back to Home
          </a>
        </div>
      </div>

      <div class="w-full flex justify-center">
        <SnakeGame client:load />
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>
